# ── Linux (Docker) ─────────────────────────────────────────────────────────────
#   cp .env.example .env
#   ./linux/setup.sh
#
# ── Linux (Native — SteamCMD, không Docker, không playit) ─────────────────────
#   cp .env.example .env
#   ./native/setup.sh
#   sudo systemctl start valheim
#   Mở firewall VPS: sudo ufw allow 2456:2457/udp
#
# ── Windows (Docker Desktop) ──────────────────────────────────────────────────
#   copy .env.example .env
#   windows\setup.bat
#   (hoặc: powershell -ExecutionPolicy Bypass -File windows\setup.ps1)
#
# Lần đầu chạy tải game server (~1 GB), đợi vài phút.
# Sau khi server chạy lần đầu, chỉnh ServerCharacters tại:
#   config/bepinex/config/<file ServerCharacters>.cfg
# Bật Single Character Mode, tắt Backup Only Mode.

# ── Playit (port forward, không cần mở router) ──────────────────────────────
# Wizard: https://playit.gg/account/agents → Docker Compose → copy SECRET_KEY
PLAYIT_SECRET_KEY=
# PLAYIT_VERSION=0.17
#
# Tạo tunnel Valheim trên dashboard:
#   Local Address = 127.0.0.1
#   Port = 2456 và 2457 (UDP)
# (playit dùng network_mode: host, valheim publish port ra localhost)

# ── Valheim Server ───────────────────────────────────────────────────────────
# UID/GID user chạy container — linux/setup.sh tự điền (tránh file root-owned)
PUID=1000
PGID=1000

SERVER_NAME=My Valheim Server
WORLD_NAME=Dedicated
SERVER_PASS=secret
SERVER_PUBLIC=false

# World modifiers (giống sửa start_server.bat trên Windows)
# https://valheim.com/support/a-guide-to-dedicated-servers/
# combat
# veryeasy, easy, hard, veryhard
# resources
# muchless, less, more, muchmore, most
# portals
# casual, hard, veryhard
# deathpenalty
# casual, veryeasy, easy, hard, hardcore
# raids
# none, muchless, less, more, muchmore
# SERVER_ARGS=-modifier combat hard -modifier resources most -modifier portals casual
# Preset (đặt trước modifier, sẽ ghi đè modifier cùng loại): SERVER_ARGS=-preset casual
# Áp dụng khi TẠO world — world "Dedicated" đã có thì đổi WORLD_NAME hoặc xóa config/worlds_local/

# SteamID64 của admin (cách nhau bởi dấu cách). Để trống khi chơi bình thường.
# Admin có devcommands + lệnh ServerCharacters (giveitem, raiseskill, ...).
# ADMINLIST_IDS=

# Múi giờ (ảnh hưởng log & lịch backup/update)
TZ=Asia/Ho_Chi_Minh

# Backup world tự động
BACKUPS=true
BACKUPS_CRON=0 * * * *
BACKUPS_MAX_AGE=3

# Tự cập nhật game khi không có người chơi
UPDATE_CRON=*/15 * * * *

# ── Mods (ServerCharacters) ──────────────────────────────────────────────────
# Bật BepInEx — image tự cài BepInExPack; mod đặt tại config/bepinex/plugins/
BEPINEX=true

# Phiên bản ServerCharacters (linux/windows/native install script)
# SERVERCHARACTERS_VERSION=1.4.16

# Phiên bản BepInExPack (native/setup.sh)
# BEPINEX_PACK_VERSION=5.4.2202

# Bật crossplay (Xbox / Microsoft Store) — cần thêm tunnel UDP port 2458 trên playit
# CROSSPLAY=true
